{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "monorepo": true,
  "projects": {
    "gateway": {
      "type": "application",
      "root": "",
      "entryFile": "main",
      "sourceRoot": "src",
      "compilerOptions": {
        "deleteOutDir": true,
        "outputPath": "dist/gateway"
      }
    },
    "user-service": {
      "type": "application",
      "root": "src/user-service",
      "entryFile": "main",
      "sourceRoot": "src/user-service/src",
      "compilerOptions": {
        "deleteOutDir": true,
        "outputPath": "dist/user-service"
      }
    }
  },
  "compilerOptions": {
    "deleteOutDir": true
  }
}
