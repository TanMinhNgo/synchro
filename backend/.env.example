# Backend env example
NODE_ENV=development
PORT=8080

# MongoDB (supports mongodb:// and mongodb+srv://)
# Local:
# MONGODB_URI=mongodb://localhost:27017/synchro
# Atlas:
# MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>/<db>?retryWrites=true&w=majority
MONGODB_URI=

# Redis for BullMQ (MUST be TCP redis:// or TLS rediss://)
# Upstash provides a Redis URL like: rediss://default:<password>@<host>:<port>
REDIS_URL=

# Upstash REST (NOT compatible with BullMQ; keep only if you use Upstash REST client elsewhere)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# NATS
# NATS_URL=nats://localhost:4222
NATS_URL=

# Sentry
SENTRY_DSN=
SENTRY_ENVIRONMENT=
SENTRY_TRACES_SAMPLE_RATE=0.1

# Auth
JWT_ACCESS_SECRET=
JWT_ACCESS_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30
REFRESH_COOKIE_NAME=refresh_token

# CORS (comma-separated)
CORS_ORIGIN=http://localhost:3000

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:8080/auth/google/callback

# Stream (Chat/Video) - getstream.io
STREAM_API_KEY=
STREAM_API_SECRET=
STREAM_APP_ID=

# AI review provider (none | openai | azure-openai)
AI_REVIEW_PROVIDER=none

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=2024-10-21
