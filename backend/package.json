{
  "name": "backend",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "npm run build:gateway && npm run build:user-service && npm run build:project-service && npm run build:task-service && npm run build:notification-service",
    "build:gateway": "nest build gateway",
    "build:user-service": "nest build user-service",
    "build:project-service": "nest build project-service",
    "build:task-service": "nest build task-service",
    "build:notification-service": "nest build notification-service",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "node -r tsconfig-paths/register node_modules/@nestjs/cli/bin/nest.js start gateway",
    "start:gateway": "node -r tsconfig-paths/register node_modules/@nestjs/cli/bin/nest.js start gateway",
    "start:user-service": "node -r tsconfig-paths/register node_modules/@nestjs/cli/bin/nest.js start user-service",
    "start:project-service": "node -r tsconfig-paths/register node_modules/@nestjs/cli/bin/nest.js start project-service",
    "start:task-service": "node -r tsconfig-paths/register node_modules/@nestjs/cli/bin/nest.js start task-service",
    "start:notification-service": "node -r tsconfig-paths/register node_modules/@nestjs/cli/bin/nest.js start notification-service",
    "start:dev": "node -r tsconfig-paths/register node_modules/@nestjs/cli/bin/nest.js start gateway --watch",
    "start:dev:gateway": "node -r tsconfig-paths/register node_modules/@nestjs/cli/bin/nest.js start gateway --watch",
    "start:dev:user-service": "node -r tsconfig-paths/register node_modules/@nestjs/cli/bin/nest.js start user-service --watch --exec \"node -r tsconfig-paths/register dist/user-service/src/main.js\"",
    "start:dev:project-service": "node -r tsconfig-paths/register node_modules/@nestjs/cli/bin/nest.js start project-service --watch --exec \"node -r tsconfig-paths/register dist/project-service/src/main.js\"",
    "start:dev:task-service": "node -r tsconfig-paths/register node_modules/@nestjs/cli/bin/nest.js start task-service --watch --exec \"node -r tsconfig-paths/register dist/task-service/src/main.js\"",
    "start:dev:notification-service": "node -r tsconfig-paths/register node_modules/@nestjs/cli/bin/nest.js start notification-service --watch --exec \"node -r tsconfig-paths/register dist/notification-service/src/main.js\"",
    "start:dev:all": "concurrently -c \"cyan.bold,yellow.bold,magenta.bold,green.bold,blue.bold\" \"npm run start:dev:gateway\" \"npm run start:dev:user-service\" \"npm run start:dev:project-service\" \"npm run start:dev:task-service\" \"npm run start:dev:notification-service\"",
    "start:debug": "node -r tsconfig-paths/register node_modules/@nestjs/cli/bin/nest.js start gateway --debug --watch",
    "start:prod": "node -r tsconfig-paths/register dist/gateway/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "seed": "node -r ts-node/register -r tsconfig-paths/register scripts/seed.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/microservices": "^11.0.1",
    "@nestjs/mongoose": "^11.0.4",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/platform-socket.io": "^11.0.1",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/websockets": "^11.0.1",
    "@sentry/nestjs": "^10.46.0",
    "argon2": "^0.44.0",
    "bullmq": "^5.71.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.4",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.3.1",
    "ioredis": "^5.10.1",
    "joi": "^18.1.1",
    "mongoose": "^9.3.3",
    "nats": "^2.29.3",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.1",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.7",
    "@types/supertest": "^6.0.2",
    "concurrently": "^9.2.1",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
